# PostgreSQL
DATABASE_URL=postgresql+psycopg://paperagent:dev_password_change_in_production@localhost:5432/paperagent
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=paperagent
POSTGRES_USER=paperagent
POSTGRES_PASSWORD=dev_password_change_in_production

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_UPLOADS=paperagent-uploads
MINIO_BUCKET_WORKSPACE=paperagent-workspace
MINIO_SECURE=false
MINIO_BUCKET_PREFIX=paperagent

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_WORKERS=4

# Worker
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
WORKER_CONCURRENCY=4

# LLM & Models
MODEL_ROUTER_PROFILE=development
MODEL_ROUTER_ENDPOINT=http://localhost:8001
EMBEDDING_MODEL_NAME=bge-m3
EMBEDDING_ENDPOINT=http://localhost:8002
RERANKER_ENDPOINT=http://localhost:8003

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_WS_URL=ws://localhost:8000

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_ENDPOINT=https://cloud.langfuse.com

# Security
SECRET_KEY=dev_secret_key_change_in_production
ALLOWED_HOSTS=localhost,127.0.0.1

# Features
ENABLE_SANDBOX=false
ENABLE_CODE_EXECUTION=false
ENABLE_LATEX_RENDERING=false

# Logging
LOG_LEVEL=INFO
