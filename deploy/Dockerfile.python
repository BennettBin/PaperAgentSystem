FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app
COPY . .
RUN pip install --no-cache-dir \
    fastapi uvicorn pydantic pydantic-settings sqlalchemy alembic "psycopg[binary]" \
    pgvector redis celery minio pymupdf langfuse opentelemetry-api \
    opentelemetry-sdk opentelemetry-exporter-otlp python-multipart aiofiles pyyaml

EXPOSE 8000
